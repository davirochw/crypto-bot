# =========================================================
# Crypto Copilot — Environment configuration
# Copy this file to `.env` and fill in your real keys.
# NEVER commit `.env` to git.
# =========================================================

# ---------- General ----------
APP_ENV=dev                   # dev | prod
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
TIMEZONE=America/Sao_Paulo

# ---------- Binance (Futures) ----------
# Read-only keys are enough for the copilot mode (no auto trading).
# Crie em: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ---------- AI provider ----------
# Options: openrouter | groq
AI_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---------- Telegram ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=true

# ---------- Engine ----------
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,BNBUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,LINKUSDT,DOTUSDT,TRXUSDT,LTCUSDT,UNIUSDT,AAVEUSDT,NEARUSDT,APTUSDT,SUIUSDT,ARBUSDT,OPUSDT,TAOUSDT
TIMEFRAMES=4h,1h,15m,5m
SCAN_INTERVAL_SECONDS=60
MIN_SCORE_TO_ALERT=70

# ---------- Risk ----------
DEFAULT_RISK_PERCENT=1.0
DEFAULT_RR_RATIO=2.0
# Stops por ATR. 2.5 = stop a ~2.5× a vol. típica do par (mais respirado).
ATR_STOP_MULT=2.5
# Piso para a distância TP-entry, em % do preço. <0.8% = lucro come taxa.
MIN_TP_PCT=0.8

# ---------- Monte Carlo pré-trade ----------
# Simula N caminhos de preço (GBM) antes de emitir cada sinal.
# Descarta setups com EV negativo ou P(TP) muito baixa.
MC_ENABLED=true
MC_SIMULATIONS=2000        # quantos caminhos. 2000 = ~15ms por par
MC_HORIZON_BARS=48         # candles à frente (48 × 15m = 12h)
MC_MIN_EV_PCT=0.0          # piso de EV em % do notional. 0 = só rejeita negativo
MC_MIN_P_TP=0.30           # piso de P(TP). 0.30 = só sinais com ≥30% chance

# ---------- Order Book Intelligence ----------
# Lê o livro público, vira "drift" do GBM. Quando o book aponta direcional,
# P(TP) sobe naturalmente pra trades alinhados com a pressão do book.
OB_ENABLED=true
OB_DEPTH_LEVELS=50         # níveis a baixar do book
OB_RANGE_PCT=1.0           # janela ao redor do mid pra somar volume (±1%)
OB_DRIFT_SCALE=0.15        # 0 = desliga, 0.15 = padrão, 0.30 = agressivo

# ---------- Position Re-evaluation (Exit Manager) ----------
# A cada scan, reavalia posições abertas e fecha as que viraram contra.
EXIT_REEVAL_ENABLED=true
EXIT_MC_EV_BAILOUT=-0.5      # se EV virar < -0.5% fecha
EXIT_MC_P_TP_BAILOUT=0.15    # se P(TP) cair < 15% fecha
EXIT_MC_HORIZON_BARS=24      # horizonte do MC de saída (12h em 15m)
EXIT_OB_FLIP_THRESHOLD=0.35  # book contra com imbalance ≥ |0.35| = fecha
EXIT_TREND_FLIP_ENABLED=true # macro trend reverteu = fecha
EXIT_TIME_STALE_HOURS=0      # 0 = sem time-stop; 8 = fecha após 8h paradas

# ---------- Dashboard ----------
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000

# ---------- Paper trade ----------
PAPER_INITIAL_BALANCE=20
PAPER_FEE_PERCENT=0.04
# Cap dinâmico (só usado quando PAPER_MARGIN_PER_TRADE=0). 0.5 = 50%/trade.
PAPER_MAX_POSITION_PCT=0.5
# Margem fixa por trade + leverage. notional = margem × leverage.
# 2 × 10 = $20 notional por posição. Com saldo $20 cabem 10 trades.
# Defina PAPER_MARGIN_PER_TRADE=0 pra voltar ao sizing dinâmico.
PAPER_MARGIN_PER_TRADE=2.0
PAPER_LEVERAGE=10.0
